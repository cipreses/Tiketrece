# General Django settings
DEBUG=True
SECRET_KEY=django-insecure-some-secret-key-goes-here
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ticket_system

# Authentication / Authorization
SUPERADMIN_EMAILS=superadmin@13dejulio.edu.ar,another_super@13dejulio.edu.ar
ENABLE_MOCK_AUTH=True

# Google OAuth Config
GOOGLE_CLIENT_ID=google-client-id-goes-here
GOOGLE_CLIENT_SECRET=google-client-secret-goes-here
REDIRECT_URI=http://localhost:8000/auth/callback/

# Production Hardening Settings (Required if DEBUG=False)
# List of host/domain names that this Django site can serve (comma-separated).
# Example for production: ALLOWED_HOSTS=tiketrece.13dejulio.edu.ar,www.tiketrece.13dejulio.edu.ar
ALLOWED_HOSTS=*

# List of trusted origins for CSRF requests (comma-separated, must include scheme).
# Example for production: CSRF_TRUSTED_ORIGINS=https://tiketrece.13dejulio.edu.ar,https://www.tiketrece.13dejulio.edu.ar
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Email and Site URL Config
# For development, EMAIL_BACKEND defaults to console backend (prints mails to terminal).
# For production SMTP configuration:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@13dejulio.edu.ar
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True
# EMAIL_TIMEOUT=10
# DEFAULT_FROM_EMAIL=no-reply@13dejulio.edu.ar
# SITE_URL=https://tickets.13dejulio.edu.ar
